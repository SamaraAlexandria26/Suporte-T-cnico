# Exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# O arquivo .env NUNCA deve ser commitado no repositório Git

# ─────────────────────────────────────────
# API / BACKEND (para uso futuro)
# ─────────────────────────────────────────
API_BASE_URL=https://api.seudominio.com
API_KEY=sua_chave_de_api_aqui
API_SECRET=seu_segredo_aqui

# ─────────────────────────────────────────
# BANCO DE DADOS (para uso futuro)
# ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techsupport
DB_USER=usuario
DB_PASSWORD=senha_segura

# ─────────────────────────────────────────
# AUTENTICAÇÃO (para uso futuro)
# ─────────────────────────────────────────
JWT_SECRET=seu_jwt_secret_aqui
SESSION_SECRET=seu_session_secret_aqui

# ─────────────────────────────────────────
# CONFIGURAÇÕES DO SISTEMA
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3000
